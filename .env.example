# PostgreSQL connection string (Neon serverless Postgres).
# Use the *pooled* connection string from the Neon console for DATABASE_URL.
# Pooled format:  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Direct format:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# (direct URL is needed for prisma migrate; set DIRECT_URL if using both)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Secret used by Better Auth to sign sessions and tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# The canonical base URL of the app as seen by Better Auth (no trailing slash).
# Local: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL of the app, used in client-side code (e.g. OG images, links).
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of origins that Better Auth will accept requests from.
# In production, set this to your deployed domain(s). Never include "*" or "localhost" in production.
# Example: https://app.example.com,https://www.example.com
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"
