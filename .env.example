# PostgreSQL connection string (Neon serverless Postgres).
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Secret used by Better Auth to sign sessions and tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# The canonical base URL of the app as seen by Better Auth (no trailing slash).
# Local: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL of the app, used in client-side code (e.g. OG images, links).
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
